async def groupid_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        message = update.effective_message
        if not message or not message.text:
            return
            
        # 1. 把用户发的消息全部变成小写
        user_text = message.text.lower()
        
        # 2. 用最稳妥的关键词包含判断（完全避开正则组件）
        if "查群id" in user_text or "查id" in user_text or "chaid" in user_text:
            chat_id = update.effective_chat.id
            chat_title = update.effective_chat.title or "未设置群名"
            
            result = (
                f"🆔 <b>当前群组信息</b>\n\n"
                f"🏷️ <b>群ID:</b> <code>{chat_id}</code>\n"
                f"📝 <b>群名称:</b> <code>{chat_title}</code>\n\n"
                f"✅ 查询成功！您当前在群组 {chat_title} 中。"
            )
            await message.reply_text(result, parse_mode="HTML")
            
    except Exception as e:
        print(f"查询失败报错: {e}")

def main():
    application = Application.builder().token(TG_BOT_TOKEN).build()
    
    application.add_handler(CommandHandler("cx", cx_command))
    application.add_handler(MessageHandler(filters.Regex(r'^[cC][xX]$'), cx_command))
    
    # 【修改这里】拦截所有纯文本消息，交给函数内部去判断是否包含“查群id”
    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, groupid_command))
    
    application.job_queue.run_repeating(check_usdt_transactions, interval=CHECK_INTERVAL, first=1)
    application.run_polling()
